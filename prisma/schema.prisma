generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./database.db"
}

model Bot {
  id           Int        @id @default(autoincrement())
  nome         String
  idade        Int        @default(24)
  cidade       String     @default("Sao Paulo")
  token        String     @unique
  grupoId      String
  ativo        Boolean    @default(true)
  ultimaMsg    DateTime?
  criadoEm     DateTime   @default(now())
  funilId      Int?
  funil        Funil?     @relation(fields: [funilId], references: [id])
  midias       Midia[]
  conversas    Conversa[]
}

model Midia {
  id        Int      @id @default(autoincrement())
  botId     Int
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  categoria String
  tipo      String
  url       String?
  legenda   String?
  criadoEm  DateTime @default(now())
}

model Funil {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  bots      Bot[]
  passos    Passo[]
  criadoEm  DateTime @default(now())
}

model Passo {
  id        Int      @id @default(autoincrement())
  funilId   Int
  funil     Funil    @relation(fields: [funilId], references: [id], onDelete: Cascade)
  ordem     Int
  texto     String?
  mediaUrl  String?
  mediaTipo String?
  delay     Int      @default(2)
  criadoEm  DateTime @default(now())
}

model Conversa {
  id           Int      @id @default(autoincrement())
  botId        Int
  bot          Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  telegramId   String
  passoAtual   Int      @default(0)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @default(now())

  @@unique([botId, telegramId])
}

model Admin {
  id    Int    @id @default(autoincrement())
  user  String @unique
  senha String
}
